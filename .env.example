# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# ID of the channel where Wazuh posts alerts
# Right-click the channel in Discord → Copy Channel ID (enable Developer Mode first)
WAZUH_CHANNEL_ID=123456789012345678

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Model slug — see https://openrouter.ai/models
# Free options:  meta-llama/llama-3.1-8b-instruct:free
#                mistralai/mistral-7b-instruct:free
# Paid options:  openai/gpt-4o
#                anthropic/claude-3.5-sonnet
#                meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional
TRIAGE_DELAY_SECONDS=2
