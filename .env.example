# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# ID of the channel where Wazuh posts alerts
# Right-click the channel in Discord → Copy Channel ID (enable Developer Mode first)
WAZUH_CHANNEL_ID=123456789012345678

# LLM Configuration — defaults to local Ollama
# For Ollama: install ollama, run `ollama pull phi3:mini`, no API key needed
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=phi3:mini

# Or use a cloud API (OpenAI, etc) — set base_url and key:
# OLLAMA_BASE_URL=https://api.openai.com/v1
# OLLAMA_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Optional
TRIAGE_DELAY_SECONDS=2
